{
	"name": "home",
	"displayName": "OpenClaw Code",
	"description": "OpenClaw Code home screen, install wizard, configuration, and status panel",
	"version": "0.2.2",
	"publisher": "openclaw",
	"license": "MIT",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished",
		"onUri"
	],
	"main": "./out/extension",
	"contributes": {
		"configuration": {
			"title": "OpenClaw",
			"properties": {
				"openclaw.cliPath": {
					"type": "string",
					"default": "",
					"description": "Absolute path to the OpenClaw CLI (overrides auto-detection)."
				}
			}
		},
		"themes": [
			{
				"label": "OpenClaw Dark",
				"uiTheme": "vs-dark",
				"path": "./themes/openclaw-dark.json"
			},
			{
				"label": "OpenClaw Light",
				"uiTheme": "vs",
				"path": "./themes/openclaw-light.json"
			}
		],
		"walkthroughs": [
			{
				"id": "occGettingStarted",
				"title": "Get Started with OCC",
				"description": "Set up your AI and theme in two quick steps.",
				"steps": [
					{
						"id": "chooseAI",
						"title": "Choose your AI",
						"description": "Pick MoltPilot free credits or connect your own API key.",
						"media": {
							"markdown": "./walkthrough/chooseAI.md"
						},
						"completionEvents": [
							"onCommand:occ.onboarding.chooseMoltPilot",
							"onCommand:occ.onboarding.chooseBYOK"
						]
					},
					{
						"id": "chooseTheme",
						"title": "Choose your theme",
						"description": "Pick OCC Dark or OCC Light — you can change this any time.",
						"media": {
							"markdown": "./walkthrough/chooseTheme.md"
						},
						"completionEvents": [
							"onCommand:occ.onboarding.darkTheme",
							"onCommand:occ.onboarding.lightTheme"
						]
					}
				]
			}
		],
		"keybindings": [
			{
				"command": "openclaw.home",
				"key": "ctrl+alt+h",
				"mac": "cmd+alt+h",
				"when": "true"
			}
		],
		"commands": [
			{
				"command": "openclaw.home",
				"title": "OpenClaw: Home"
			},
			{
				"command": "openclaw.configure",
				"title": "OpenClaw: Configure"
			},
			{
				"command": "openclaw.install",
				"title": "OpenClaw: Install"
			},
			{
				"command": "openclaw.status",
				"title": "OpenClaw: Status"
			}
		]
	},
	"scripts": {
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@types/node": "^20.19.35",
		"@types/vscode": "^1.85.0",
		"typescript": "^5.9.3"
	},
	"icon": "media/icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/damoahdominic/occ.git"
	}
}
